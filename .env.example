# Server config
PORT=5000

# Optional: comma-separated CORS allowlist (e.g. https://app.example.com,https://admin.example.com).
# Leave unset to allow all origins.
# CORS_ORIGINS=

# Timezone — product is Pakistan-only, booking times computed in PKT.
# Setting this here means schedule math is correct regardless of host OS default.
TZ=Asia/Karachi

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash
