# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicitly treat common source/text files as text.
*.ts   text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary assets should never be normalized.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
